# ===========================================
# Notes-Taking App — Environment Variables
# ===========================================
# Copy this file to .env before running:
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=notes_db
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=notes_password_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
